<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\EasySynQ.Domain\EasySynQ.Domain.csproj" />
    <ProjectReference Include="..\EasySynQ.Data\EasySynQ.Data.csproj" />
    <ProjectReference Include="..\EasySynQ.Services\EasySynQ.Services.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.7" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Serilog.Sinks.Debug" Version="3.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Test seam. The MSBuild ItemGroup form (.NET 5+) is preferred over the
      [assembly: InternalsVisibleTo] attribute because it lives in the
      project file alongside the rest of the dependency declarations and
      survives auto-generated AssemblyInfo regen.
    -->
    <InternalsVisibleTo Include="EasySynQ.Tests" />
  </ItemGroup>

</Project>

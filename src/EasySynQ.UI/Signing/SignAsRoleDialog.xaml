<Window x:Class="EasySynQ.UI.Signing.SignAsRoleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:signing="clr-namespace:EasySynQ.UI.Signing"
        mc:Ignorable="d"
        Title="EasySynQ — Sign as which role?"
        Width="380"
        Height="380"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance Type=signing:SignAsRoleViewModel, IsDesignTimeCreatable=False}">

    <!--
        Layout strategy: single card centered in the window. Mirrors
        LoginWindow / BootstrapWindow visual language (card, brand
        radius, spacing tokens). The dialog is forward-looking
        scaffolding (ADR 0009 §"What ships in C4") — visual polish
        will be revisited in C6 when the dialog is wired into actual
        signing flows from the document detail view.
    -->
    <Grid>
        <Border Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Width="320"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>

                <!-- Title -->
                <TextBlock Style="{StaticResource TextStyleHeading}"
                           Text="Sign as which role?"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <!-- Subtitle -->
                <TextBlock Style="{StaticResource TextStyleCaption}"
                           Text="Pick which role this signature represents."
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16" />

                <!--
                    Role picker. ListBox with single-select; SelectedItem
                    binds two-way to SelectedRole. Each item renders as a
                    RadioButton via a DataTemplate so the visual is the
                    role-picker affordance the ADR specifies, but
                    selection state lives in the ListBox (no per-item
                    IsChecked binding to plumb).
                -->
                <ListBox x:Name="RoleListBox"
                         ItemsSource="{Binding Roles}"
                         SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                         SelectionMode="Single"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,0,0,20"
                         AutomationProperties.Name="Eligible roles">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!--
                                RadioButton inside a DataTemplate uses
                                IsHitTestVisible=False so clicks pass
                                through to the ListBoxItem (the ListBox
                                is the actual selection authority).
                                IsChecked binds to the ListBoxItem's
                                IsSelected so the visual matches the
                                selection state.
                            -->
                            <RadioButton Content="{Binding}"
                                         GroupName="SignAsRole"
                                         IsHitTestVisible="False"
                                         Focusable="False"
                                         Margin="2"
                                         IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Mode=OneWay}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Action row: Cancel + OK -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Width="88"
                            Height="32"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Cancel" />
                    <Button x:Name="OkButton"
                            Style="{StaticResource ButtonPrimary}"
                            Content="Sign as this role"
                            Command="{Binding OkCommand}"
                            IsDefault="True"
                            Width="160"
                            Height="32"
                            AutomationProperties.Name="Sign as this role" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>

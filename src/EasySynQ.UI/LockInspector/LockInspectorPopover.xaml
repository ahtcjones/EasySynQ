<UserControl x:Class="EasySynQ.UI.LockInspector.LockInspectorPopover"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lock="clr-namespace:EasySynQ.UI.LockInspector"
             mc:Ignorable="d"
             Width="380"
             d:DataContext="{d:DesignInstance Type=lock:LockInspectorViewModel, IsDesignTimeCreatable=False}">

    <!--
        ADR 0012 C7b — Lock Inspector popover content.

        Hosted inside a WPF Popup primitive (configured in
        LockInspectorPrompter) rather than a top-level Window so
        click-outside dismissal works without focus-stealing games.
        The Border below is the visual surface — BrushSurface2
        background, BrushBorder 1px, 6px corner radius — matching
        the C6a viewer-error banner treatment. The Popup itself
        positions this control near the cursor and auto-closes on
        outside click (StaysOpen=False).
    -->
    <Border Background="{StaticResource BrushSurface2}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="14">
        <StackPanel Orientation="Vertical">

            <!-- Header -->
            <TextBlock Style="{StaticResource TextStyleSubheading}"
                       Text="Why is this locked?"
                       Margin="0,0,0,10" />

            <!-- Loading state -->
            <TextBlock Style="{StaticResource TextStyleCaption}"
                       Foreground="{StaticResource BrushTextDim}"
                       Text="Loading lock-reason chain…"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,4" />

            <!-- Not-locked state -->
            <TextBlock Style="{StaticResource TextStyleBody}"
                       Foreground="{StaticResource BrushTextDim}"
                       Text="This entity is not currently locked."
                       Visibility="{Binding IsLocked, Converter={StaticResource InvertBoolToVisibility}}" />

            <!-- Chain — visible only when IsLocked is true. -->
            <ItemsControl ItemsSource="{Binding Chain}"
                          Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,8">

                            <!-- Link card: tag chip + detail. -->
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource BrushPurple}"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        VerticalAlignment="Top"
                                        Margin="0,2,8,0">
                                    <TextBlock Text="{Binding Tag}"
                                               Foreground="{StaticResource BrushText}"
                                               Style="{StaticResource TextStyleLabel}" />
                                </Border>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding Id}"
                                               Style="{StaticResource TextStyleMonoSmall}"
                                               Foreground="{StaticResource BrushText}" />
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource TextStyleCaption}"
                                               Foreground="{StaticResource BrushTextDim}"
                                               TextWrapping="Wrap"
                                               MaxWidth="280" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Connector row — only for non-terminal links. -->
                            <TextBlock Margin="22,4,0,0"
                                       Foreground="{StaticResource BrushTextDim}"
                                       Style="{StaticResource TextStyleCaption}"
                                       Visibility="{Binding IsTerminal, Converter={StaticResource InvertBoolToVisibility}}">
                                <Run Text="↳ because " />
                                <Run Text="{Binding Because}" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="EasySynQ.UI.Placeholders.PulseDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ph="clr-namespace:EasySynQ.UI.Placeholders"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="500"
             d:DataContext="{d:DesignInstance Type=ph:PulseDashboardViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="640"
                    Margin="40">
            <TextBlock Style="{StaticResource TextStyleHeading}"
                       Text="Pulse Dashboard"
                       HorizontalAlignment="Center" />
            <!--
                Austere by design for E2.4: the live alerts and good-news
                tiles already live in the slide-out Pulse drawer (top-right
                Pulse button). A richer dashboard with summary widgets
                (FPY trend, NCR Pareto, recent activity, etc.) is on the
                Phase 1 polish list — drop them in this StackPanel when
                they land.
            -->
            <TextBlock Text="Live alerts and good-news tiles appear in the drawer (Pulse button, top right). A dashboard view with summary widgets is on the Phase 1 polish list."
                       Foreground="{StaticResource BrushTextDim}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,24,0,0" />
        </StackPanel>
    </Grid>
</UserControl>

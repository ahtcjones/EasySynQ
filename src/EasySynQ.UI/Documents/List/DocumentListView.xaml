<UserControl x:Class="EasySynQ.UI.Documents.List.DocumentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:list="clr-namespace:EasySynQ.UI.Documents.List"
             xmlns:detail="clr-namespace:EasySynQ.UI.Documents.Detail"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="700"
             d:DataContext="{d:DesignInstance Type=list:DocumentListViewModel, IsDesignTimeCreatable=False}"
             Loaded="OnLoadedAsync">

    <UserControl.Resources>
        <!--
            Data template for the embedded detail view. The list view
            hosts the DocumentDetailViewModel directly via
            DocumentListViewModel.DetailViewModel — when the user picks
            a row, this template renders the detail surface in the
            right pane.
        -->
        <DataTemplate DataType="{x:Type detail:DocumentDetailViewModel}">
            <detail:DocumentDetailView />
        </DataTemplate>
    </UserControl.Resources>

    <!--
        Two-pane layout: list on the left (380px), detail on the right
        (fills). Matches the prototype's documents-section layout and
        the "click a row, see detail" interaction.
    -->
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left pane: header + Create button + list grid -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Section title -->
            <TextBlock Grid.Row="0"
                       Style="{StaticResource TextStyleHeading}"
                       Text="Documents"
                       Margin="0,0,0,12" />

            <!-- Create button — hidden entirely when the user lacks
                 Document.Create per the C6a no-stubs rule. -->
            <Button Grid.Row="1"
                    Style="{StaticResource ButtonPrimary}"
                    Content="+ New document"
                    Command="{Binding CreateCommand}"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,12"
                    Visibility="{Binding CanCreate, Converter={StaticResource BoolToVisibility}}"
                    AutomationProperties.Name="Create new document" />

            <!-- Document list -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DataGrid x:Name="DocumentsGrid"
                          ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{StaticResource BrushSurface2}"
                          Foreground="{StaticResource BrushText}"
                          FontSize="12"
                          AutomationProperties.Name="Documents list">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Number"
                                            Binding="{Binding Number}"
                                            Width="*" />
                        <DataGridTextColumn Header="Title"
                                            Binding="{Binding Title}"
                                            Width="*" />
                        <DataGridTextColumn Header="Rev"
                                            Binding="{Binding CurrentRevisionLabel}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding LifecycleDisplay}"
                                            Width="Auto" />
                        <!-- Lock-glyph cell (ADR 0012 C7b).
                             Renders a clickable red lock when the row's
                             entity is in a lockout state; the cell's
                             button is bound to the list VM's
                             OpenLockInspectorCommand with the row item
                             as parameter so the prompter inspects the
                             right (LockedEntityType, LockedEntityId).
                             Header is intentionally blank — the column's
                             meaning is conveyed by the glyph itself plus
                             the row tooltip. -->
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.OpenLockInspectorCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="6,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            ToolTip="Why is this locked?"
                                            Visibility="{Binding LockedEntityType, Converter={StaticResource NullOrEmptyToVisibility}}">
                                        <TextBlock Text="🔒"
                                                   Foreground="{StaticResource BrushRed}"
                                                   Style="{StaticResource TextStyleMonoSmall}" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Right pane: detail view (when an item is selected) -->
        <Border Grid.Column="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <!-- Empty-state placeholder visible only when no row
                     selected. NullToVisibility maps null → Visible. -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Style="{StaticResource TextStyleCaption}"
                               Text="Pick a document to see its details."
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- The detail VM renders via the DataTemplate above.
                     When DetailViewModel is null (no selection), the
                     ContentControl renders nothing and the placeholder
                     above shows; when non-null the placeholder
                     collapses via the converter. -->
                <ContentControl Content="{Binding DetailViewModel}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

<Window x:Class="EasySynQ.UI.Documents.EditMetadata.EditMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:em="clr-namespace:EasySynQ.UI.Documents.EditMetadata"
        mc:Ignorable="d"
        Title="EasySynQ — Edit metadata"
        Width="420"
        Height="320"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance Type=em:EditMetadataViewModel, IsDesignTimeCreatable=False}">

    <!--
        Smaller-than-Create dialog: only Number + Title, both
        pre-populated with current values. OK gated on both non-empty.
    -->
    <Grid>
        <Border Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Width="360"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>

                <!-- Title -->
                <TextBlock Style="{StaticResource TextStyleHeading}"
                           Text="Edit document metadata"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />

                <!-- Number -->
                <TextBlock Style="{StaticResource TextStyleLabel}"
                           Text="Number"
                           Margin="0,0,0,4" />
                <TextBox x:Name="NumberTextBox"
                         Text="{Binding Number, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"
                         AutomationProperties.Name="Document number" />

                <!-- Title -->
                <TextBlock Style="{StaticResource TextStyleLabel}"
                           Text="Title"
                           Margin="0,0,0,4" />
                <TextBox x:Name="TitleTextBox"
                         Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,20"
                         AutomationProperties.Name="Document title" />

                <!-- Action row: Cancel + OK -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Width="88"
                            Height="32"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="Cancel" />
                    <Button x:Name="OkButton"
                            Style="{StaticResource ButtonPrimary}"
                            Content="Save"
                            Command="{Binding OkCommand}"
                            IsDefault="True"
                            Width="88"
                            Height="32"
                            AutomationProperties.Name="Save metadata" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>

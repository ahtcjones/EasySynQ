<UserControl x:Class="EasySynQ.UI.Documents.Detail.DocumentDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:detail="clr-namespace:EasySynQ.UI.Documents.Detail"
             xmlns:controls="clr-namespace:EasySynQ.UI.Documents.Controls"
             xmlns:comments="clr-namespace:EasySynQ.UI.Documents.Comments"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             d:DataContext="{d:DesignInstance Type=detail:DocumentDetailViewModel, IsDesignTimeCreatable=False}"
             Loaded="OnLoadedAsync">

    <!--
        ADR 0008 C6b stop 7 — detail view layout.
        Rows: metadata header, last-return-reason banner (when
        present), affordance row, viewer error banner, main content
        area (viewer left + InReview side panel right when
        applicable).
    -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Metadata header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Number + title -->
            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Style="{StaticResource TextStyleMonoSmall}"
                           Text="{Binding Document.Number}"
                           Foreground="{StaticResource BrushTextDim}" />
                <TextBlock Style="{StaticResource TextStyleHeading}"
                           Text="{Binding Document.Title}"
                           Margin="0,2,0,0" />
            </StackPanel>

            <!-- Status pill + lock-glyph affordance.
                 The lock-glyph button is only visible when the current
                 entity is in a lockout state (ADR 0012 C7b); clicking
                 it opens the lock-inspector popover via the prompter.
                 The pill itself stays purely informational so users
                 don't accidentally open the inspector when reading
                 the lifecycle label. -->
            <StackPanel Grid.Row="0" Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Command="{Binding OpenLockInspectorCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,2"
                        Margin="0,0,8,0"
                        ToolTip="Why is this locked?"
                        Visibility="{Binding CanOpenLockInspector, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="🔒"
                               Foreground="{StaticResource BrushRed}"
                               Style="{StaticResource TextStyleMonoSmall}" />
                </Button>
                <Border Background="{StaticResource BrushSurface3}"
                        CornerRadius="14"
                        Padding="12,4,12,4"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentRevisionLabel}"
                                   Style="{StaticResource TextStyleMonoSmall}"
                                   Foreground="{StaticResource BrushText}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="·" Foreground="{StaticResource BrushTextFaint}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LifecycleDisplay}"
                                   Style="{StaticResource TextStyleMonoSmall}"
                                   Foreground="{StaticResource BrushTextDim}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- C6b: Last return-to-draft reason. Visible only when the
             current revision is in Draft after having been returned
             from In Review (LastReturnToDraftReason non-null). Author
             sees the reviewer's reason while editing. Amber-tinted
             per UI discipline (review-needed signal). -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushAmberBg}"
                BorderBrush="{StaticResource BrushAmber}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8,12,8"
                Margin="0,0,0,12"
                Visibility="{Binding HasLastReturnToDraftReason, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="Returned for edits — reason:"
                           Style="{StaticResource TextStyleLabel}"
                           Foreground="{StaticResource BrushAmber}"
                           Margin="0,0,0,2" />
                <TextBlock Text="{Binding LastReturnToDraftReason}"
                           TextWrapping="Wrap"
                           AutomationProperties.Name="Last return-to-draft reason" />
            </StackPanel>
        </Border>

        <!-- Affordance row.
             Per the C6a no-stubs rule, buttons are HIDDEN (not just
             disabled) when their CanExecute is false. C6b adds three
             new buttons (Submit for review / Review and sign /
             Return to draft); their visibility binds to the matching
             CanXxx flag. -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Edit metadata"
                    Command="{Binding EditMetadataCommand}"
                    Visibility="{Binding CanEditMetadata, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Edit document metadata" />
            <Button Content="Replace PDF"
                    Command="{Binding ReplacePdfCommand}"
                    Visibility="{Binding CanReplacePdf, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Replace attached PDF" />
            <Button Content="Submit for review"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding SubmitForReviewCommand}"
                    Visibility="{Binding CanSubmitForReview, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Submit document for review" />
            <Button Content="Review and sign"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding ReviewAndSignCommand}"
                    Visibility="{Binding CanReviewAndSign, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Review and sign as reviewer" />
            <Button Content="Return to draft"
                    Command="{Binding ReturnToDraftCommand}"
                    Visibility="{Binding CanReturnToDraft, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Return document to draft" />
            <Button Content="Hard-delete draft"
                    Command="{Binding HardDeleteDraftCommand}"
                    Visibility="{Binding CanHardDelete, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Hard-delete this draft" />
            <Button Content="Print"
                    Command="{Binding PrintCommand}"
                    Visibility="{Binding CanPrint, Converter={StaticResource BoolToVisibility}}"
                    AutomationProperties.Name="Print document detail" />
        </StackPanel>

        <!-- Viewer error banner. -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushRedBg}"
                BorderBrush="{StaticResource BrushRed}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8,12,8"
                Margin="0,0,0,12"
                Visibility="{Binding HasViewerLoadError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ViewerErrorMessage}"
                       Foreground="{StaticResource BrushRed}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       AutomationProperties.Name="PDF viewer load error" />
        </Border>

        <!-- Main content area: viewer on left, InReview side panel
             (assignments + comments) on right. Side panel collapses
             when not InReview so the viewer fills the row. -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- PDF viewer / placeholder -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface2}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding VaultDocumentUrl, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Style="{StaticResource TextStyleCaption}"
                                   Text="No PDF attached to this revision."
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                    <controls:PdfViewerControl
                        x:Name="PdfViewer"
                        DocumentPath="{Binding VaultDocumentUrl}"
                        ContentRoot="{Binding ContentRoot}"
                        NavigationFailed="OnViewerNavigationFailed"
                        Visibility="{Binding VaultDocumentUrl, Converter={StaticResource NullOrEmptyToVisibility}}" />
                </Grid>
            </Border>

            <!-- InReview side panel (assignments + comments).
                 Width-fixed at 320px so the viewer keeps a usable
                 main pane on smaller windows. -->
            <Border Grid.Column="1"
                    Width="320"
                    Margin="12,0,0,0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Visibility="{Binding ShowAssignmentPanel, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Assigned-reviewer panel -->
                    <TextBlock Grid.Row="0"
                               Style="{StaticResource TextStyleSubheading}"
                               Text="Assigned reviewers"
                               Margin="0,0,0,8" />

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding Assignments}"
                                  Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type detail:AssignedReviewerRow}">
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ReviewerDisplayName}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ReviewerUsername}"
                                                   FontSize="11"
                                                   Opacity="0.7" />
                                    </StackPanel>
                                    <!-- Status badge. Color discipline:
                                         Pending = amber, Signed = green,
                                         Discarded = neutral grey. -->
                                    <Border Grid.Column="1"
                                            CornerRadius="10"
                                            Padding="8,2,8,2"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource BrushSurface3}">
                                        <TextBlock Text="{Binding Status}"
                                                   Style="{StaticResource TextStyleMonoSmall}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Comment panel — embedded UserControl with its
                         own VM. Visibility binds to ShowCommentPanel
                         (same gate as the assignment panel header but
                         separate for clarity). DataContext binds to
                         the parent VM's CommentPanel property. -->
                    <comments:CommentPanelControl Grid.Row="2"
                                                  DataContext="{Binding CommentPanel}"
                                                  Visibility="{Binding DataContext.ShowCommentPanel, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

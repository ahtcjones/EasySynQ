<UserControl x:Class="EasySynQ.UI.Documents.Detail.DocumentDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:detail="clr-namespace:EasySynQ.UI.Documents.Detail"
             xmlns:controls="clr-namespace:EasySynQ.UI.Documents.Controls"
             mc:Ignorable="d"
             d:DesignWidth="720"
             d:DesignHeight="700"
             d:DataContext="{d:DesignInstance Type=detail:DocumentDetailViewModel, IsDesignTimeCreatable=False}"
             Loaded="OnLoadedAsync">

    <!--
        Four-row layout:
        - Metadata header (Number/Title) + lifecycle + revision label
        - Affordance row (Edit Metadata / Replace PDF / Hard-Delete)
        - Viewer error banner (Auto height; collapsed when no error)
        - PdfViewerControl (fills)
    -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Metadata header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Number + title -->
            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Style="{StaticResource TextStyleMonoSmall}"
                           Text="{Binding Document.Number}"
                           Foreground="{StaticResource BrushTextDim}" />
                <TextBlock Style="{StaticResource TextStyleHeading}"
                           Text="{Binding Document.Title}"
                           Margin="0,2,0,0" />
            </StackPanel>

            <!-- Status pill -->
            <Border Grid.Row="0" Grid.Column="1"
                    Background="{StaticResource BrushSurface3}"
                    CornerRadius="14"
                    Padding="12,4,12,4"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentRevisionLabel}"
                               Style="{StaticResource TextStyleMonoSmall}"
                               Foreground="{StaticResource BrushText}"
                               Margin="0,0,8,0" />
                    <TextBlock Text="·" Foreground="{StaticResource BrushTextFaint}" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding LifecycleDisplay}"
                               Style="{StaticResource TextStyleMonoSmall}"
                               Foreground="{StaticResource BrushTextDim}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Affordance row.
             Per the C6a no-stubs rule, buttons are HIDDEN (not just
             disabled) when their CanExecute is false. The state-aware
             VM toggles CanEditMetadata / CanReplacePdf / CanHardDelete
             based on lifecycle + permissions + authorship; the
             Visibility binding via BoolToVisibility consumes those
             flags. -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Edit metadata"
                    Command="{Binding EditMetadataCommand}"
                    Visibility="{Binding CanEditMetadata, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Edit document metadata" />
            <Button Content="Replace PDF"
                    Command="{Binding ReplacePdfCommand}"
                    Visibility="{Binding CanReplacePdf, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,8,0"
                    AutomationProperties.Name="Replace attached PDF" />
            <Button Content="Hard-delete draft"
                    Command="{Binding HardDeleteDraftCommand}"
                    Visibility="{Binding CanHardDelete, Converter={StaticResource BoolToVisibility}}"
                    AutomationProperties.Name="Hard-delete this draft" />
        </StackPanel>

        <!-- Viewer error banner. Visibility binds to
             HasViewerLoadError; the VM also resets the flag on every
             successful LoadAsync so a stale banner doesn't linger
             across navigation. Red palette per CLAUDE.md UI rules
             (red = failure / lockout). -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushRedBg}"
                BorderBrush="{StaticResource BrushRed}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8,12,8"
                Margin="0,0,0,12"
                Visibility="{Binding HasViewerLoadError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ViewerErrorMessage}"
                       Foreground="{StaticResource BrushRed}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       AutomationProperties.Name="PDF viewer load error" />
        </Border>

        <!-- PDF viewer (or "no PDF attached" placeholder) -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushSurface2}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <!-- Placeholder shown when no VaultBlob is attached. -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding VaultDocumentUrl, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Style="{StaticResource TextStyleCaption}"
                               Text="No PDF attached to this revision."
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Viewer is collapsed when no URL so its WebView2
                     instance doesn't try to navigate to nothing. The
                     control raises NavigationFailed which the
                     code-behind forwards to the VM's banner state. -->
                <controls:PdfViewerControl
                    x:Name="PdfViewer"
                    DocumentPath="{Binding VaultDocumentUrl}"
                    ContentRoot="{Binding ContentRoot}"
                    NavigationFailed="OnViewerNavigationFailed"
                    Visibility="{Binding VaultDocumentUrl, Converter={StaticResource NullOrEmptyToVisibility}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

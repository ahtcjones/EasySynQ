<UserControl x:Class="EasySynQ.UI.Documents.Controls.PdfViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">

    <!--
        ADR 0010 C5 — embeds Microsoft Edge WebView2 control hosting
        the bundled PDF.js viewer (Assets/pdfviewer/web/viewer.html).
        Initialized lazily on Loaded; navigation triggered by the
        DocumentPath dependency property. Single child for the whole
        UserControl surface so the viewer fills the available area.
    -->
    <Grid>
        <wv2:WebView2 x:Name="WebView" />
    </Grid>

</UserControl>

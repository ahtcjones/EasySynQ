<Window x:Class="EasySynQ.UI.Bootstrap.BootstrapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:bootstrap="clr-namespace:EasySynQ.UI.Bootstrap"
        mc:Ignorable="d"
        Title="EasySynQ — First-Run Setup"
        Width="420"
        Height="640"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=bootstrap:BootstrapViewModel, IsDesignTimeCreatable=False}">

    <!--
        Layout mirrors LoginWindow.xaml — single-cell Grid containing a
        centered card and the bottom-right version stamp. Card content
        adds DisplayName and Confirm Password rows beyond the Login form;
        the visual language (brand mark, typography, error region, primary
        button) is shared via the same resource tokens.
    -->
    <Grid>

        <!-- Setup card -->
        <Border Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Width="360"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>

                <!-- Brand mark — identical to LoginWindow. -->
                <Border Width="56"
                        Height="56"
                        CornerRadius="14"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource ColorAccent}" Offset="0" />
                            <GradientStop Color="{StaticResource ColorPurple}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="EQ"
                               FontFamily="{StaticResource FontFamilyBody}"
                               FontSize="20"
                               FontWeight="ExtraBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Title -->
                <TextBlock Style="{StaticResource TextStyleHeading}"
                           Text="First-Run Setup"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <!-- Subtitle -->
                <TextBlock Style="{StaticResource TextStyleCaption}"
                           Text="Create the initial administrator account"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <!-- Username -->
                <TextBlock Style="{StaticResource TextStyleLabel}"
                           Text="Username"
                           Margin="0,0,0,6" />
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         HorizontalAlignment="Stretch"
                         Margin="0,0,0,12"
                         AutomationProperties.Name="Username" />

                <!-- Display name -->
                <TextBlock Style="{StaticResource TextStyleLabel}"
                           Text="Display name"
                           Margin="0,0,0,6" />
                <TextBox x:Name="DisplayNameTextBox"
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         HorizontalAlignment="Stretch"
                         Margin="0,0,0,12"
                         AutomationProperties.Name="Display name" />

                <!--
                    Password. PasswordBox.Password is unbindable by design;
                    the code-behind's PasswordChanged handler calls
                    ViewModel.SetPasswords(...) with both boxes' current
                    values on each keystroke. The CommandParameter binding
                    used by LoginWindow is unnecessary here because the VM
                    already holds the values via SetPasswords.
                -->
                <TextBlock Style="{StaticResource TextStyleLabel}"
                           Text="Password"
                           Margin="0,0,0,6" />
                <PasswordBox x:Name="PasswordBox"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,12"
                             PasswordChanged="PasswordChanged"
                             AutomationProperties.Name="Password" />

                <!-- Confirm password -->
                <TextBlock Style="{StaticResource TextStyleLabel}"
                           Text="Confirm password"
                           Margin="0,0,0,6" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,16"
                             PasswordChanged="PasswordChanged"
                             AutomationProperties.Name="Confirm password" />

                <!--
                    Error region. Same shape as LoginWindow's — visible only
                    when HasError is true. ErrorMessage is the human line;
                    LogCorrelationId is the mono support-reference line,
                    populated only for system errors (null for password
                    mismatch / policy violations).
                -->
                <Border CornerRadius="6"
                        Padding="10,8,10,8"
                        Margin="0,0,0,16"
                        Background="{StaticResource BrushRedBg}"
                        BorderBrush="{StaticResource BrushRed}"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource BrushRed}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource TextStyleMonoSmall}"
                                   Text="{Binding LogCorrelationId}"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LogCorrelationId, Converter={StaticResource NullOrEmptyToVisibility}}" />
                    </StackPanel>
                </Border>

                <!--
                    Submit button. Command/CanExecute drives IsEnabled
                    transparently. IsDefault=True wires Enter to submit.
                    No CommandParameter — passwords already live in the
                    VM via SetPasswords.
                -->
                <Button x:Name="CreateButton"
                        Style="{StaticResource ButtonPrimary}"
                        Content="Create administrator"
                        Command="{Binding CreateCommand}"
                        IsDefault="True"
                        Height="36"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Create administrator" />

            </StackPanel>
        </Border>

        <!--
            Version + environment stamp. Same hardcoded placeholder as
            LoginWindow; replaced by reflection-pulled values in a future
            chunk.
        -->
        <TextBlock Style="{StaticResource TextStyleMonoSmall}"
                   Text="DEV · v0.1.0-alpha"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,12,8" />

    </Grid>
</Window>

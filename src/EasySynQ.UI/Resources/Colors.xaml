<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        EasySynQ palette tokens — derived from docs/UI_PROTOTYPE.html and pinned
        by SPEC §4.4 ("General UI Discipline"). Every consumer references these
        token names; raw hex values do not belong in any other XAML file.

        SPEC §4.4, verbatim:

            "Purple is reserved for cross-cutting linkage affordances — linked
            records, module surfaces, customer concession references, and
            similar non-severity cues. Purple is never used for pass/fail or
            any severity tier. The four-color severity discipline
            (red / green / amber / blue) is exclusive to state communication;
            purple sits outside it as a 'this points to something else' accent."

        Severity therefore lives entirely inside red / green / amber / blue.
        ColorPurple / BrushPurple are listed below for linkage usage only;
        any use of them for severity is a spec violation.
    -->

    <!-- Surface scale: app background through elevated surfaces. -->
    <Color x:Key="ColorBg">#FF0F1419</Color>
    <Color x:Key="ColorSurface">#FF161C24</Color>
    <Color x:Key="ColorSurface2">#FF1D242E</Color>
    <Color x:Key="ColorSurface3">#FF252D39</Color>

    <!-- Borders. -->
    <Color x:Key="ColorBorder">#FF2A3441</Color>
    <Color x:Key="ColorBorderStrong">#FF3A4654</Color>

    <!-- Text: primary, secondary, tertiary/label. -->
    <Color x:Key="ColorText">#FFE6EDF3</Color>
    <Color x:Key="ColorTextDim">#FF9AA7B4</Color>
    <Color x:Key="ColorTextFaint">#FF6B7785</Color>

    <!-- Severity discipline: blue / green / amber / red. Each paired with a low-saturation
         background companion for inline pill / chip surfaces. -->
    <Color x:Key="ColorAccent">#FF4A9EFF</Color>
    <Color x:Key="ColorAccentDim">#FF2D5A8F</Color>
    <Color x:Key="ColorGreen">#FF3FB950</Color>
    <Color x:Key="ColorGreenBg">#FF0F2E1A</Color>
    <Color x:Key="ColorAmber">#FFD29922</Color>
    <Color x:Key="ColorAmberBg">#FF2E2410</Color>
    <Color x:Key="ColorRed">#FFF85149</Color>
    <Color x:Key="ColorRedBg">#FF2E1414</Color>

    <!-- Badge background variants. Translucent overlays of the severity hue
         at alpha 0x33 (~0.2), matching the prototype's nav-badge styling
         (rgba(248,81,73,0.2) / rgba(210,153,34,0.2)). DIFFERENT from the
         *Bg solids above: those are full-saturation tile/chip surfaces,
         these are see-through pills that pick up the surface they sit on.
         Two visual purposes, two named tokens. -->
    <Color x:Key="ColorBadgeRedBg">#33F85149</Color>
    <Color x:Key="ColorBadgeAmberBg">#33D29922</Color>

    <!-- Linkage accent. See the SPEC §4.4 block at the top of this file —
         NEVER use this color (or its brush) for severity. -->
    <Color x:Key="ColorPurple">#FFA371F7</Color>

    <!-- Brush wrappers. Consumers should bind to BrushXxx in nearly all cases;
         the raw ColorXxx resources are kept available for gradient stops and
         programmatic color manipulation only. -->
    <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColorBg}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurface2" Color="{StaticResource ColorSurface2}" />
    <SolidColorBrush x:Key="BrushSurface3" Color="{StaticResource ColorSurface3}" />

    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushBorderStrong" Color="{StaticResource ColorBorderStrong}" />

    <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColorText}" />
    <SolidColorBrush x:Key="BrushTextDim" Color="{StaticResource ColorTextDim}" />
    <SolidColorBrush x:Key="BrushTextFaint" Color="{StaticResource ColorTextFaint}" />

    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentDim" Color="{StaticResource ColorAccentDim}" />
    <SolidColorBrush x:Key="BrushGreen" Color="{StaticResource ColorGreen}" />
    <SolidColorBrush x:Key="BrushGreenBg" Color="{StaticResource ColorGreenBg}" />
    <SolidColorBrush x:Key="BrushAmber" Color="{StaticResource ColorAmber}" />
    <SolidColorBrush x:Key="BrushAmberBg" Color="{StaticResource ColorAmberBg}" />
    <SolidColorBrush x:Key="BrushRed" Color="{StaticResource ColorRed}" />
    <SolidColorBrush x:Key="BrushRedBg" Color="{StaticResource ColorRedBg}" />

    <!-- Translucent badge backgrounds — see the ColorBadge*Bg block above. -->
    <SolidColorBrush x:Key="BrushBadgeRedBg" Color="{StaticResource ColorBadgeRedBg}" />
    <SolidColorBrush x:Key="BrushBadgeAmberBg" Color="{StaticResource ColorBadgeAmberBg}" />

    <SolidColorBrush x:Key="BrushPurple" Color="{StaticResource ColorPurple}" />

</ResourceDictionary>

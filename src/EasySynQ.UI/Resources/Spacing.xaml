<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Spacing scale and preset paddings/margins. Values are pixel-aligned
        to docs/UI_PROTOTYPE.html and represent the only sanctioned spacing
        magnitudes in the app — no inline magic numbers in views.

        Use the SpaceXxx Double tokens when building Thickness / Margin /
        Padding values dynamically. The Thickness presets below are reserved
        for the most repeated combinations (control padding, form rhythm).
    -->

    <sys:Double x:Key="SpaceXS">4</sys:Double>
    <sys:Double x:Key="SpaceS">6</sys:Double>
    <sys:Double x:Key="SpaceSM">8</sys:Double>
    <sys:Double x:Key="SpaceM">10</sys:Double>
    <sys:Double x:Key="SpaceL">12</sys:Double>
    <sys:Double x:Key="SpaceXL">16</sys:Double>
    <sys:Double x:Key="SpaceXXL">20</sys:Double>
    <sys:Double x:Key="SpaceXXXL">28</sys:Double>

    <!-- Button padding: prototype .btn { padding: 6px 12px }. -->
    <Thickness x:Key="PaddingButton">12,6,12,6</Thickness>

    <!-- Text input padding: prototype .why-input ~ padding 10/12; symmetric
         vertical pad keeps the 12px text vertically centered in a ~30px row. -->
    <Thickness x:Key="PaddingInput">10,8,10,8</Thickness>

    <!-- Vertical rhythm between stacked form rows. -->
    <Thickness x:Key="MarginFieldRow">0,0,0,12</Thickness>

</ResourceDictionary>

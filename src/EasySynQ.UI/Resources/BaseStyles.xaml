<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        BaseStyles — implicit (no x:Key, TargetType-keyed) styles for the
        controls used across the shell and the login screen. Every style in
        this file references tokens from Colors / Typography / Spacing
        rather than literal values.

        Implicit styles auto-apply to every control of the target type that
        does not declare its own Style="…". Keyed variants (ButtonPrimary,
        etc.) live at the bottom of the file and opt in via Style="{StaticResource …}".
    -->

    <!--
        Implicit Window style. Background/Foreground/FontFamily/FontSize
        propagate by inheritance to every descendant FrameworkElement that
        does not override them locally. This is how the dark palette reaches
        the existing empty MainWindow without touching its XAML.
    -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BrushBg}" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <!-- Implicit TextBlock style: body defaults. Keyed Typography styles
         (TextStyleHeading, TextStyleLabel, …) override these explicitly. -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <!--
        TextBox: dark surface, accent-color focus ring, rounded corners.
        WPF TextBox has no CornerRadius property, so we re-template around a
        Border that hosts the framework's PART_ContentHost ScrollViewer.
        The template keeps the standard Padding / Background / BorderBrush
        TemplateBindings so the style's setters and any per-instance overrides
        keep working without surprise.
    -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushSurface2}" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource PaddingInput}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushText}" />
        <Setter Property="SelectionBrush" Value="{StaticResource BrushAccentDim}" />
        <Setter Property="SelectionOpacity" Value="0.6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource BrushTextFaint}" />
                            <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PasswordBox: same visual treatment as TextBox. PasswordBox's default
         template also exposes a ScrollViewer named PART_ContentHost, so the
         template shape is identical. -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource BrushSurface2}" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource PaddingInput}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushText}" />
        <Setter Property="SelectionBrush" Value="{StaticResource BrushAccentDim}" />
        <Setter Property="SelectionOpacity" Value="0.6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource BrushTextFaint}" />
                            <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Button: dark surface, 6px rounded corners, hover lifts to surface-3,
        pressed darkens to surface. Template uses pure TemplateBindings so
        Style.Triggers (and BasedOn derivatives like ButtonPrimary) can drive
        Background / BorderBrush directly via Setters rather than re-templating.
    -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushSurface2}" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource PaddingButton}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSurface3}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
            </Trigger>
            <!-- Pressed darkens slightly below resting; gives a subtle inset
                 feel without the cartoonish "pushed in" treatment. -->
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSurface}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorderStrong}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource BrushTextFaint}" />
                <Setter Property="Opacity" Value="0.6" />
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ButtonPrimary: accent-filled call-to-action variant. Derives from
         the implicit Button style and only overrides what differs (palette,
         weight, and the hover/pressed colors that should remain in the
         accent family rather than fall back to the surface ramp). -->
    <Style x:Key="ButtonPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource BrushAccent}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <!-- Hover color is pulled verbatim from prototype .btn.primary:hover.
                 Literal hex used here intentionally: this exact shade does not
                 appear elsewhere in the palette and does not warrant promotion
                 to a named token until we see a second use site. -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF5AA8FF" />
                <Setter Property="BorderBrush" Value="#FF5AA8FF" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushAccentDim}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrushAccentDim}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ButtonGhost: transparent at rest, default hover/pressed/disabled.
         Matches the prototype's .btn.ghost rule (transparent background,
         standard border color). BasedOn the implicit Button style means the
         base style's Style.Triggers (IsMouseOver → BrushSurface3,
         IsPressed → BrushSurface, IsEnabled=false → dim) flow through
         unchanged — Style triggers from the base style inherit alongside
         its setters, and trigger setters override at runtime regardless of
         the derived style's resting setter. No trigger overrides needed;
         verified by inspection of the base style's structure above. -->
    <Style x:Key="ButtonGhost" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!--
        ToolTip: dark-theme implicit style. The framework's default ToolTip
        renders a light-tan SystemColors.InfoBrush background with black
        text — illegible against EasySynQ's dark host theme. Retemplate
        around a Border so the surface, foreground, and a 1px Border line
        all consume palette tokens; rounded corners (CornerRadius="4")
        match the popover/banner treatment elsewhere in the shell.

        Affects every ToolTip in the app (e.g., the C7b lock-glyph tooltips
        on the detail-view status pill and the list-view lock column, plus
        any MainWindow chrome tooltips). No keyed variant — every tooltip
        wants the dark treatment.
    -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource BrushSurface2}" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        DataGrid: dark-theme defaults for the DocumentListView grid (the
        only DataGrid in the app today). The view's local DataGrid
        attribute setup already covers Background / RowBackground /
        AlternatingRowBackground / Foreground / BorderThickness — these
        implicit setters fill in the remaining chrome (grid-line colors,
        scrollbar surrounds). Per-view overrides win when present.
    -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BrushSurface2}" />
    </Style>

    <!--
        DataGridColumnHeader: dark surface with dim text, semibold and
        slightly smaller than body so the header row reads as
        metadata, not as content. The framework's default template uses
        SystemColors.ControlBrushKey for the background — light gray that
        bleeds through against the dark host theme. Retemplate around a
        Border so Background / Foreground / BorderBrush all consume
        palette tokens, with a 1px bottom-only border line separating
        the header row from the data rows below.
    -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource BrushSurface2}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextDim}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBody}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        DataGridRow: hover lifts to Surface3; selection uses AccentDim so
        the selected row is visible against alternating-row striping. The
        framework default uses SystemColors.HighlightBrushKey (Windows blue
        selection) which clashes with the palette.
    -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSurface3}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushAccentDim}" />
                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        DataGridCell: clear the framework's default cell-selection chrome
        so the selected-row appearance comes from the DataGridRow style
        above (consistent surface lift) rather than per-cell tinting.
    -->
    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="6,4"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
